# Production / staging .env for a VPS compose stack (spec 14). On the VPS this lives
# UNTRACKED at /srv/cosimosi-<env>/.env — NEVER commit real values (this file is keys
# only). Copy to that path and fill in per environment. docker-compose.prod.yml and the
# Caddyfile read these.

# Image tag the deploy step writes (the commit SHA). compose reads it for BOTH
# `pull` and `up -d` (do not pass IMAGE_TAG inline — it wouldn't reach `up`).
IMAGE_TAG=latest

# --- Database (Supabase) — two URLs on purpose (spec 14 §6) ---
# App runtime → TRANSACTION POOLER (port 6543). default_query_exec_mode=simple_protocol
# is REQUIRED: the transaction pooler shares backend connections, so pgx's named
# prepared-statement cache collides across clients ("prepared statement ... already
# exists", SQLSTATE 42P05) — simple protocol disables prepared statements.
DATABASE_URL=postgres://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require&default_query_exec_mode=simple_protocol
# Migrations only (goose step) → DIRECT connection (port 5432). DDL must NOT go through
# the pooler. Used by the deploy workflow, not the app container.
DIRECT_DATABASE_URL=postgres://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# --- HTTP / proxy ---
PORT=8080
# This stack's DNS alias on the shared `edge` docker network. The single edge Caddy
# (deploy/edge, /srv/edge) terminates TLS for api.<도메인>/api.staging.<도메인> and
# proxies here — per-stack caddys would fight over ports 80/443.
API_UPSTREAM=cosimosi-api-staging   # cosimosi-api-prod (prod) | cosimosi-api-staging (staging)
# Allowed browser origin = this environment's frontend domain.
CORS_ORIGIN=https://cosimosi.example.com

# --- Auth (Supabase, same project as the frontend) ---
# Project base URL → JWKS for verifying ES256/RS256 tokens (Supabase default). REQUIRED,
# else real logins are rejected. Use this environment's Supabase project URL.
SUPABASE_PROJECT_URL=https://<ref>.supabase.co
# Legacy HS256 shared secret (Dashboard → Settings → API → JWT Secret). Optional when the
# project uses asymmetric signing keys; needed only for HS256 tokens / dev tokens.
SUPABASE_JWT_SECRET=

# --- AI embedder (spec 05) ---
AI_EMBEDDER=mock          # mock (keyless) | openai
OPENAI_API_KEY=           # required when AI_EMBEDDER=openai

# AI extraction has NO env knob (spec 34): it follows the admin console — real LLM
# extraction while a console selection is ACTIVE, keyless mock otherwise. LLM
# provider API keys are entered in the console (/admin) and stored AES-256-GCM-
# encrypted in the DB (master key below) — they do not belong in this file.

# --- Admin console (spec 34) ---
# AdminService allowlist: comma-separated Supabase user UUIDs (Dashboard →
# Authentication → Users) and/or account emails (JWT sub/email claims).
# Empty = everyone rejected (fail-closed).
ADMIN_USER_IDS=
# AES-256-GCM master key for LLM API keys stored via the admin console.
# base64 32 bytes — generate: openssl rand -base64 32. Server env ONLY.
LLM_KEY_ENCRYPTION_KEY=

# --- Observability (Sentry, spec 14 §9) ---
SENTRY_DSN=               # empty = disabled (no-op)
SENTRY_ENVIRONMENT=production   # production | staging
# 프론트 관측 변수(VITE_SENTRY_DSN/VITE_SENTRY_ENVIRONMENT·VITE_POSTHOG_KEY/VITE_POSTHOG_HOST,
# spec 18)는 이 파일이 아니라 Cloudflare Worker 빌드 변수에 넣는다 — DEPLOY.md §3.
