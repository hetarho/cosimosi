{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* FSD path alias (TS 6+: paths resolve relative to this tsconfig) */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    /* erasableSyntaxOnly is intentionally NOT set here: protoc-gen-es emits real
       TS `enum`s (e.g. Mood) into src/shared/api/gen, which is non-erasable
       syntax. Generated transport types are infrastructure (constitution §5);
       Vite/esbuild transpile enums fine. tsconfig.node.json keeps it on. */
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
