{
  "name": "cosimosi",
  "version": "0.0.1",
  "private": true,
  "description": "Engram universe diary — your memories as a living 3D cosmos",
  "scripts": {
    "setup": "node scripts/check-node-version.mjs && node scripts/setup.mjs",
    "dev": "concurrently -n web,api -c cyan,magenta \"pnpm --filter @cosimosi/web dev\" \"pnpm run dev:api\"",
    "dev:api": "docker compose up api",
    "dev:blog": "pnpm --filter @cosimosi/blog dev",
    "dev:web": "pnpm --filter @cosimosi/web dev",
    "dev:mobile": "pnpm --filter @cosimosi/mobile start",
    "ios": "pnpm --filter @cosimosi/mobile ios",
    "android": "pnpm --filter @cosimosi/mobile android",
    "gen": "node scripts/gen-values.mjs && node scripts/gen-messages.mjs && node scripts/gen-tokens.mjs && node scripts/gen.mjs",
    "gen:values": "node scripts/gen-values.mjs",
    "gen:messages": "node scripts/gen-messages.mjs",
    "gen:tokens": "node scripts/gen-tokens.mjs",
    "gen:proto": "node scripts/gen.mjs proto",
    "buf:gen": "node scripts/gen.mjs proto",
    "gen:sql": "node scripts/gen.mjs sql",
    "spec:plan": "node scripts/new-plan.mjs",
    "spec:change": "node scripts/new-change.mjs",
    "spec:code-review": "node scripts/new-code-review.mjs",
    "spec:job": "node scripts/new-job.mjs",
    "db:migrate": "node scripts/db.mjs up",
    "db:status": "node scripts/db.mjs status",
    "db:down": "node scripts/db.mjs down",
    "db:reset": "node scripts/db.mjs reset",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "lint": "pnpm check:node && pnpm lint:web && pnpm lint:mobile && pnpm lint:fsd:layout && pnpm lint:api && pnpm lint:observability && pnpm lint:language && pnpm lint:raw-strings && pnpm lint:persistence && pnpm lint:spec && pnpm lint:comments",
    "lint:web": "pnpm --filter @cosimosi/web lint",
    "lint:mobile": "pnpm --filter @cosimosi/mobile lint",
    "lint:fsd:layout": "node scripts/lint-fsd-layout.mjs",
    "lint:api": "node scripts/go-check.mjs fmt",
    "lint:observability": "node scripts/check-observability-boundaries.mjs",
    "lint:language": "node scripts/lint-ubiquitous-language.mjs",
    "lint:raw-strings": "node scripts/lint-raw-strings.mjs",
    "lint:persistence": "node scripts/check-persistence-isolation.mjs",
    "lint:spec": "node scripts/check-spec-hygiene.mjs",
    "lint:comments": "node scripts/lint-comment-history.mjs",
    "lint:comments:probe": "node scripts/lint-comment-history.mjs --probe",
    "lint:raw-strings:probe": "node scripts/lint-raw-strings.mjs --probe",
    "typecheck": "pnpm typecheck:config && pnpm typecheck:emotion && pnpm typecheck:memory-logic && pnpm typecheck:memory && pnpm typecheck:force-sim && pnpm typecheck:universe && pnpm typecheck:universe-render && pnpm typecheck:3d-renderer && pnpm typecheck:api-client && pnpm typecheck:auth && pnpm typecheck:client-cache && pnpm typecheck:observability && pnpm typecheck:state-machine && pnpm typecheck:i18n && pnpm typecheck:ui && pnpm typecheck:web && pnpm typecheck:mobile && pnpm typecheck:blog",
    "typecheck:config": "pnpm --filter @cosimosi/config typecheck",
    "typecheck:emotion": "pnpm --filter @cosimosi/emotion typecheck",
    "typecheck:memory-logic": "pnpm --filter @cosimosi/memory-logic typecheck",
    "typecheck:memory": "pnpm --filter @cosimosi/memory typecheck",
    "typecheck:universe": "pnpm --filter @cosimosi/universe typecheck",
    "typecheck:universe-render": "pnpm --filter @cosimosi/universe-render typecheck",
    "typecheck:force-sim": "pnpm --filter @cosimosi/force-sim typecheck",
    "typecheck:3d-renderer": "pnpm --filter @cosimosi/3d-renderer typecheck",
    "typecheck:ui": "pnpm --filter @cosimosi/ui typecheck",
    "typecheck:api-client": "pnpm --filter @cosimosi/api-client typecheck",
    "typecheck:auth": "pnpm --filter @cosimosi/auth typecheck",
    "typecheck:client-cache": "pnpm --filter @cosimosi/client-cache typecheck",
    "typecheck:observability": "pnpm --filter @cosimosi/observability typecheck",
    "typecheck:state-machine": "pnpm --filter @cosimosi/state-machine typecheck",
    "typecheck:i18n": "pnpm --filter @cosimosi/i18n typecheck",
    "typecheck:web": "pnpm --filter @cosimosi/web typecheck",
    "typecheck:mobile": "pnpm --filter @cosimosi/mobile typecheck",
    "typecheck:blog": "pnpm --filter @cosimosi/blog typecheck",
    "test": "pnpm test:values && pnpm test:guards && pnpm test:emotion && pnpm test:memory-logic && pnpm test:memory && pnpm test:force-sim && pnpm test:universe && pnpm test:universe-render && pnpm test:3d-renderer && pnpm test:api-client && pnpm test:auth && pnpm test:client-cache && pnpm test:observability && pnpm test:state-machine && pnpm test:i18n && pnpm test:ui && pnpm test:web && pnpm test:mobile && pnpm test:api",
    "test:values": "node --test scripts/gen-values.test.mjs",
    "test:guards": "node --test scripts/check-persistence-isolation.test.mjs",
    "test:emotion": "pnpm --filter @cosimosi/emotion test",
    "test:memory-logic": "pnpm --filter @cosimosi/memory-logic test",
    "test:memory": "pnpm --filter @cosimosi/memory test",
    "test:universe": "pnpm --filter @cosimosi/universe test",
    "test:universe-render": "pnpm --filter @cosimosi/universe-render test",
    "test:3d-renderer": "pnpm --filter @cosimosi/3d-renderer test",
    "test:force-sim": "pnpm --filter @cosimosi/force-sim test",
    "test:api-client": "pnpm --filter @cosimosi/api-client test",
    "test:ui": "pnpm --filter @cosimosi/ui test",
    "test:auth": "pnpm --filter @cosimosi/auth test",
    "test:client-cache": "pnpm --filter @cosimosi/client-cache test",
    "test:observability": "pnpm --filter @cosimosi/observability test",
    "test:state-machine": "pnpm --filter @cosimosi/state-machine test",
    "test:i18n": "pnpm --filter @cosimosi/i18n test",
    "test:web": "pnpm --filter @cosimosi/web test",
    "test:mobile": "pnpm --filter @cosimosi/mobile test",
    "test:api": "node scripts/go-check.mjs test",
    "vet:api": "node scripts/go-check.mjs vet",
    "check:api": "node scripts/go-check.mjs",
    "check:gen": "node scripts/check-generated.mjs",
    "check:node": "node scripts/check-node-version.mjs",
    "check": "pnpm check:node && pnpm lint && pnpm typecheck && pnpm test && pnpm build:web && pnpm build:blog && pnpm vet:api && pnpm build:api && pnpm check:gen",
    "build:web": "pnpm --filter @cosimosi/web build",
    "build:blog": "pnpm --filter @cosimosi/blog build",
    "build:api": "node scripts/go-check.mjs build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.20.2",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=22.13"
  },
  "pnpm": {
    "patchedDependencies": {
      "@react-three/fiber@9.6.1": "patches/@react-three__fiber@9.6.1.patch"
    }
  }
}
