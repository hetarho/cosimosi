{
  "name": "cosimosi",
  "version": "0.0.1",
  "private": true,
  "description": "Engram universe diary — your memories as a living 3D cosmos",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "concurrently -n web,api -c cyan,magenta \"pnpm --filter ./frontend dev\" \"pnpm run dev:api\"",
    "dev:api": "docker compose --profile dev up backend",
    "dev:web": "pnpm --filter ./frontend dev",
    "gen": "node scripts/gen-values.mjs && node scripts/gen.mjs",
    "gen:values": "node scripts/gen-values.mjs",
    "gen:proto": "node scripts/gen.mjs proto",
    "buf:gen": "node scripts/gen.mjs proto",
    "gen:sql": "node scripts/gen.mjs sql",
    "spec:plan": "node scripts/new-plan.mjs",
    "spec:change": "node scripts/new-change.mjs",
    "spec:code-review": "node scripts/new-refactor-report.mjs",
    "spec:job": "node scripts/new-job.mjs",
    "db:migrate": "node scripts/db.mjs up",
    "db:status": "node scripts/db.mjs status",
    "db:down": "node scripts/db.mjs down",
    "db:reset": "node scripts/db.mjs reset",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "build:web": "pnpm --filter ./frontend build",
    "build:api": "cd backend && go build -o bin/api ./cmd/api",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20"
  }
}
