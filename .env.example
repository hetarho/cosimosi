# Backend
PORT=8080
DATABASE_URL=postgres://cosimosi:cosimosi@localhost:5432/cosimosi?sslmode=disable
# COSIMOSI_CORS_ORIGINS is unset in dev — the API falls back to localhost dev origins
# (handler.go defaultCORSOrigins). Prod sets it per env (.env.production.example).
# Supabase auth — the RPC interceptor verifies access tokens locally:
#  - SUPABASE_PROJECT_URL (e.g. https://<ref>.supabase.co): fetches/caches the project JWKS
#    to verify asymmetric Supabase tokens. SUPABASE_URL is also accepted as an alias.
#  - SUPABASE_JWT_SECRET (Dashboard → Settings → API → JWT Secret): verifies legacy HS256
#    tokens. Optional if your project uses asymmetric keys.
# With neither set, protected RPCs fail closed (Unauthenticated).
SUPABASE_PROJECT_URL=
SUPABASE_JWT_SECRET=

# AI embedding provider. "mock" = keyless deterministic vectors (default,
# enables keyless E2E); "openai" = text-embedding-3-small (requires OPENAI_API_KEY).
AI_EMBEDDER=mock
OPENAI_API_KEY=
# AI extraction has NO env knob (spec 34): it follows the admin console — real LLM
# extraction while a console selection is ACTIVE, keyless mock otherwise. LLM
# provider API keys are entered in the console (/admin) and stored AES-256-GCM-
# encrypted in the DB (master key below) — they do not belong in this file.

# Admin console (spec 34). ADMIN_USER_IDS = AdminService allowlist — comma-separated
# Supabase user UUIDs (Dashboard → Authentication → Users) and/or account emails,
# matched against the JWT sub/email claims. Email entries only match tokens with
# user_metadata.email_verified=true (OAuth/confirmed signups) — legacy dev tokens
# without that flag must be allowlisted by UUID. Empty = everyone rejected (fail-closed).
ADMIN_USER_IDS=
# Master key for AES-256-GCM envelope encryption of LLM API keys stored via the
# admin console. base64 32 bytes — generate: openssl rand -base64 32. Server env
# ONLY (never in DB/repo); unset → key writes rejected (FailedPrecondition).
LLM_KEY_ENCRYPTION_KEY=

# Invite membership gate (spec 41) — closed-beta gate ON TOP of auth. true (default): users must
# redeem an invite code (issued in /admin → 초대 코드 탭) once before the universe accepts them;
# non-members are routed to /invite. false: the gate is transparent (everyone a member) — the
# removable beta gate switched off without deleting its code/tables.
INVITE_GATE_ENABLED=true

# Dev sign-in bypass (local only, never in a production build). `pnpm dev` skips the Supabase
# login: the web boots an always-authenticated fake session as VITE_DEV_USER_ID, and the api's
# dev verifier accepts ONLY the fake-token-<COSIMOSI_DEV_USER_ID> bearer for that one user.
# COSIMOSI_DEV_AUTH is the on/off flag (truthy = on); VITE_DEV_USER_ID and COSIMOSI_DEV_USER_ID
# must be the SAME id (seed it with scripts/seed-dev-universe.sql). Mobile follows the same
# COSIMOSI_DEV_USER_ID automatically — it is generated into dev-user.gen.ts on mobile dev start
# (default 'dev-user'), so all three clients stay in sync with no hand-editing. Leave all three
# blank to use real Supabase auth. A CI build FAILS AT BUILD TIME if VITE_DEV_USER_ID is set (a
# dev-auth bundle can never be shipped); locally you keep it for `pnpm dev` and the runtime assert
# is the backstop.
COSIMOSI_DEV_AUTH=
COSIMOSI_DEV_USER_ID=
VITE_DEV_USER_ID=

# Frontend (Vite-prefixed vars are exposed to the browser)
VITE_API_URL=http://localhost:8080
# Supabase Auth — browser-exposed. Project URL + publishable key (sb_publishable_…)
# from the Supabase dashboard → Connect (or Settings → API). "publishable" = 예전 anon key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Frontend observability (spec 18) — 전부 비우면 no-op(로컬 기본). 프로덕션 값은
# Cloudflare Worker → Settings → Build → Variables and secrets에 넣는다(DEPLOY.md §3).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
# PostHog 제품 지표 — 프로젝트 API key(phc_…) + 호스트(미설정 시 https://us.i.posthog.com).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
# Sentry release 태깅 — 보통 설정 불필요: CF Workers 빌드에선 vite.config가
# WORKERS_CI_COMMIT_SHA로 자동 주입하고, 로컬 빌드는 release 태깅을 생략한다.
VITE_APP_VERSION=
