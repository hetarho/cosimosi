# Backend
PORT=8080
DATABASE_URL=postgres://cosimosi:cosimosi@localhost:5432/cosimosi?sslmode=disable
# CORS_ORIGIN is set in docker-compose.yml (compose env) only — not needed here (spec 13).
# Supabase auth — the RPC interceptor verifies access tokens two ways:
#  - SUPABASE_PROJECT_URL (e.g. https://<ref>.supabase.co): fetches the project JWKS to
#    verify ES256/RS256 tokens (Supabase's DEFAULT signing). Set this — without it, real
#    Supabase logins are rejected (signing method ES256 is invalid).
#  - SUPABASE_JWT_SECRET (Dashboard → Settings → API → JWT Secret): verifies legacy HS256
#    tokens. Optional if your project uses asymmetric keys.
# With neither set, protected RPCs fail closed (Unauthenticated).
SUPABASE_PROJECT_URL=
SUPABASE_JWT_SECRET=

# AI embedding provider (spec 05). "mock" = keyless deterministic vectors (default,
# enables keyless E2E); "openai" = text-embedding-3-small (requires OPENAI_API_KEY).
AI_EMBEDDER=mock
OPENAI_API_KEY=

# Frontend (Vite-prefixed vars are exposed to the browser)
VITE_API_URL=http://localhost:8080
# Supabase Auth — browser-exposed. Project URL + publishable key (sb_publishable_…)
# from the Supabase dashboard → Connect (or Settings → API). "publishable" = 예전 anon key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
