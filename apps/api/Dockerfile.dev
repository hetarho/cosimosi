# Foundation dev image: runs the api under air for hot reload. docker-compose
# bind-mounts the source into /app and persists the module cache in a volume, so
# no COPY here. air (installed into /go/bin at build time) watches /app and
# rebuilds ./cmd/api on every save — see .air.toml.
FROM golang:1.26
WORKDIR /app
# Pin Air to an explicit release: `@latest` lets an upstream change break `pnpm dev:api` with no
# repo diff or CI signal (this dev image isn't built by CI). Bump deliberately.
RUN go install github.com/air-verse/air@v1.65.3
EXPOSE 8080
CMD ["air", "-c", ".air.toml"]
