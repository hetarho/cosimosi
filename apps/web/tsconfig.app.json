{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    // @cosimosi/i18n ships typed JS (Paraglide JSDoc output) — read it for types, don't type-check it.
    "allowJs": true,
    "checkJs": false,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // No erasableSyntaxOnly: the generated Connect client (@cosimosi/api-client
    // src/gen) carries proto-pinned TypeScript enums, and this app is
    // Vite-transpiled, never type-stripped, so the restriction buys nothing here.
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
