{
  "name": "@cosimosi/mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "gen:dev-user": "node ../../scripts/gen-mobile-env.mjs",
    "android": "pnpm run gen:dev-user && react-native run-android",
    "ios": "pnpm run gen:dev-user && react-native run-ios",
    "lint": "eslint . && pnpm run lint:boundaries:probe",
