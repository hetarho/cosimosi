    "@react-native/typescript-config": "0.86.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.17",
    "@types/three": "^0.185.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.19.0",
    "eslint-plugin-boundaries": "^6.0.2",
