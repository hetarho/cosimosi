{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    // The renderer package owns three/R3F (its peers) and holds both DOM (canvas host)
    // and React Native (*.native canvas host) code, so the typecheck sees both worlds.
    "types": ["node", "react", "three", "react-native"]
  },
  "include": ["src"]
}
