{
  "name": "@cosimosi/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "react-native": "./src/index.native.ts",
      "default": "./src/index.ts"
    },
    "./theme.css": "./src/theme.gen.css",
    "./base.css": "./src/base.css",
    "./tokens": "./src/tokens.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "react-native": ">=0.80"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "0.86.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
